{
  "extends": ["stylelint-config-standard", "stylelint-config-html/svelte"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "theme",
          "config",
          "source",
          "utility",
          "custom-variant"
        ]
      }
    ]
  }
}
