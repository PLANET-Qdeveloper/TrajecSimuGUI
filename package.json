    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format:fe": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\" --ignore-unknown",
    "lint:fe": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format:be": "cargo fmt",
    "lint:be": "cargo clippy --fix --allow-dirty --allow-staged",
    "fix": "pnpm run format:fe && pnpm run lint:fe && pnpm run format:be && pnpm run lint:be",
    "tauri": "tauri"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
